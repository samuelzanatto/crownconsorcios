---
// src/components/Header/Header.astro
---

<header class="header">
  <div class="container header-container">
    <a href="/" class="logo">
      <img src="/logo.png" alt="Múltipla Representações" />
    </a>

    <button class="menu-toggle" aria-label="Abrir menu" id="mobile-menu-btn">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>

    <nav class="desktop-nav" id="main-nav">
      <ul>
        <li><a href="/" class="active">HOME</a></li>
        <li><a href="#quem-somos">QUEM SOMOS</a></li>
        <li><a href="#seguros">SEGUROS</a></li>
        <li><a href="#consorcio-imobiliario">CONSÓRCIO IMOBILIÁRIO</a></li>
        <li><a href="#consorcio-automotivo">CONSÓRCIO AUTOMOTIVO</a></li>
      </ul>
      <div class="actions">
        <button class="btn-primary" id="open-budget-dialog">SOLICITAR ORÇAMENTO</button>
      </div>
    </nav>
  </div>
</header>

<style>
  .header {
    background: white;
    position: sticky;
    top: 0;
    z-index: 999;
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 110px;
    gap: 64px;
    padding: 0 40px;
    max-width: 1560px;
    margin: 0 auto;
    position: relative;
  }

  .logo {
    z-index: 1000;
  }

  .logo img {
    height: 36px;
    object-fit: contain;
    filter: brightness(0);
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    flex: 1;
    justify-content: flex-end;
  }

  .desktop-nav ul {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 32px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .desktop-nav a {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-main);
    text-transform: uppercase;
    transition: color 0.3s;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .desktop-nav a:hover,
  .desktop-nav a.active {
    color: var(--primary);
  }

  .actions {
    display: flex;
    align-items: center;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 30px;
    height: 21px;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 1000;
  }

  .menu-toggle .bar {
    height: 3px;
    width: 100%;
    background-color: var(--text-main);
    border-radius: 3px;
    transition: all 0.3s ease;
  }

  .menu-toggle.open .bar:nth-child(1) {
    transform: translateY(9px) rotate(45deg);
  }
  .menu-toggle.open .bar:nth-child(2) {
    opacity: 0;
  }
  .menu-toggle.open .bar:nth-child(3) {
    transform: translateY(-9px) rotate(-45deg);
  }

  @media (max-width: 1024px) {
    .logo img {
      height: 28px;
    }
  }

  @media (max-width: 992px) {
    .header-container {
      height: 80px;
      padding: 0 20px;
    }

    .menu-toggle {
      display: flex;
    }

    .desktop-nav {
      position: absolute;
      top: 80px;
      left: 0;
      width: 100%;
      background: white;
      box-shadow: 0 10px 15px rgba(0,0,0,0.1);
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 0;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease-in-out, padding 0.3s ease-in-out;
      gap: 30px;
      z-index: 998;
    }

    .desktop-nav.open {
      max-height: 500px;
      padding: 30px 20px;
    }

    .desktop-nav ul {
      position: static;
      transform: none;
      flex-direction: column;
      align-items: center;
      gap: 20px;
      width: 100%;
    }

    .desktop-nav a {
      font-size: 16px;
    }

    .actions {
      width: 100%;
      justify-content: center;
    }
    
    .actions .btn-primary {
      width: 100%;
    }
  }
</style>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mainNav = document.getElementById('main-nav');
  const navLinks = mainNav?.querySelectorAll('a');

  if (menuBtn && mainNav) {
    menuBtn.addEventListener('click', () => {
      menuBtn.classList.toggle('open');
      mainNav.classList.toggle('open');
    });
  }

  if (navLinks) {
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        menuBtn?.classList.remove('open');
        mainNav?.classList.remove('open');
      });
    });
  }

  const btnMobile = document.getElementById("open-budget-dialog");
  if (btnMobile) {
    btnMobile.addEventListener("click", () => {
      const dialogArea = document.getElementById("budget-dialog-area");
      if (dialogArea) {
        dialogArea.style.display = "flex";
        requestAnimationFrame(() => {
          dialogArea.classList.add("show");
          const bottomSheet = dialogArea.querySelector(".bottom-sheet");
          if (bottomSheet) bottomSheet.classList.add("show");
        });
      }
    });
  }
</script>
