---
// src/components/Hero/Hero.astro
---

<section class="hero-section">
  <div class="hero-container container">
    <div class="hero-content">
      <div class="partners-badge">
        <span class="partners-text">Parceiros Autorizados:</span>
        <div class="partners-logos">
          <img src="/images/hs.png" alt="HS Consórcios" />
          <img src="/images/servopa.svg" alt="Consórcio Servopa" />
          <img src="/images/magalu.png" alt="Consórcio Magalu" />
          <img src="/images/embracon.png" alt="Consórcio Embracon" />
        </div>
      </div>
      <h1>
        <em>Inteligência</em> para construir,<br /><em>estratégia</em> para crescer.
      </h1>
      <p class="hero-description">
        Mais do que crédito, oferecemos estratégia, inteligência financeira e
        construção de patrimônio — sem juros e com planejamento estruturado para
        suas conquistas.
      </p>

      <div class="hero-info-bar" id="hero-form">
        <!-- Localização -->
        <div class="info-item">
          <span class="info-label">Localização</span>
          <div class="custom-select" data-name="localizacao">
            <button
              type="button"
              class="select-trigger"
              aria-haspopup="listbox"
            >
              <span class="select-value">Campo Grande</span>
              <svg
                class="select-arrow"
                width="10"
                height="6"
                viewBox="0 0 10 6"
                fill="none"
              >
                <path
                  d="M1 1l4 4 4-4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"></path>
              </svg>
            </button>
            <ul class="select-dropdown" role="listbox">
              <li role="option" data-value="Campo Grande" class="selected">
                Campo Grande
              </li>
              <li role="option" data-value="Dourados">Dourados</li>
              <li role="option" data-value="Três Lagoas">Três Lagoas</li>
              <li role="option" data-value="Corumbá">Corumbá</li>
              <li role="option" data-value="Outra cidade">Outra cidade</li>
            </ul>
            <input type="hidden" name="localizacao" value="Campo Grande" />
          </div>
        </div>

        <div class="info-divider"></div>

        <!-- Consórcio -->
        <div class="info-item">
          <span class="info-label">Consórcio</span>
          <div class="custom-select" data-name="consorcio">
            <button
              type="button"
              class="select-trigger"
              aria-haspopup="listbox"
            >
              <span class="select-value">Imobiliário</span>
              <svg
                class="select-arrow"
                width="10"
                height="6"
                viewBox="0 0 10 6"
                fill="none"
              >
                <path
                  d="M1 1l4 4 4-4"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"></path>
              </svg>
            </button>
            <ul class="select-dropdown" role="listbox">
              <li role="option" data-value="Imobiliário" class="selected">
                Imobiliário
              </li>
              <li role="option" data-value="Automotivo">Automotivo</li>
              <li role="option" data-value="Imobiliário e Automotivo">Ambos</li>
            </ul>
            <input type="hidden" name="consorcio" value="Imobiliário" />
          </div>
        </div>

        <div class="info-divider"></div>

        <!-- Entrada -->
        <div class="info-item">
          <span class="info-label">Entrada</span>
          <input
            type="text"
            class="info-input"
            id="hero-entrada"
            name="entrada"
            value="R$ 10.000"
            placeholder="R$ 10.000"
          />
        </div>

        <button type="button" class="btn-simulacao" id="hero-submit-btn">
          Faça uma simulação
        </button>
      </div>
    </div>

    <div class="hero-image-wrapper">
      <img src="/images/casa.png" alt="Casa moderna" class="hero-img" />
    </div>
  </div>
</section>

<script>
  // Custom select logic
  document
    .querySelectorAll(".hero-info-bar .custom-select")
    .forEach((select) => {
      const trigger = select.querySelector(
        ".select-trigger",
      ) as HTMLButtonElement;
      const dropdown = select.querySelector(
        ".select-dropdown",
      ) as HTMLUListElement;
      const valueSpan = select.querySelector(
        ".select-value",
      ) as HTMLSpanElement;
      const hiddenInput = select.querySelector(
        'input[type="hidden"]',
      ) as HTMLInputElement;
      const options = select.querySelectorAll('[role="option"]');

      trigger?.addEventListener("click", (e) => {
        e.stopPropagation();
        // Close all other dropdowns first
        document.querySelectorAll(".custom-select.open").forEach((s) => {
          if (s !== select) s.classList.remove("open");
        });
        select.classList.toggle("open");
      });

      options.forEach((option) => {
        option.addEventListener("click", () => {
          const value = (option as HTMLElement).dataset.value || "";
          valueSpan.textContent = option.textContent;
          hiddenInput.value = value;
          options.forEach((o) => o.classList.remove("selected"));
          option.classList.add("selected");
          select.classList.remove("open");
        });
      });
    });

  // Close dropdowns on outside click
  document.addEventListener("click", () => {
    document
      .querySelectorAll(".custom-select.open")
      .forEach((s) => s.classList.remove("open"));
  });

  // Currency mask for entrada
  const entradaInput = document.getElementById(
    "hero-entrada",
  ) as HTMLInputElement;
  entradaInput?.addEventListener("focus", () => {
    if (entradaInput.value === "R$ 10.000") {
      entradaInput.select();
    }
  });

  entradaInput?.addEventListener("input", () => {
    let v = entradaInput.value.replace(/\D/g, "");
    if (v) {
      const num = parseInt(v, 10);
      entradaInput.value = "R$ " + num.toLocaleString("pt-BR");
    } else {
      entradaInput.value = "";
    }
  });

  // Submit → open dialog with pre-filled data
  const heroSubmitBtn = document.getElementById("hero-submit-btn");
  heroSubmitBtn?.addEventListener("click", () => {
    const heroBar = document.getElementById("hero-form")!;
    const localizacao = (
      heroBar.querySelector('[name="localizacao"]') as HTMLInputElement
    ).value;
    const consorcio = (
      heroBar.querySelector('[name="consorcio"]') as HTMLInputElement
    ).value;
    const entrada = (
      document.getElementById("hero-entrada") as HTMLInputElement
    ).value;

    // Fill dialog custom selects via exposed API
    const setSelect = (window as any).__setDialogSelect;
    const dialogLocSelect = document.querySelector(
      '.dialog-custom-select[data-name="localizacao"]',
    );
    const dialogConsSelect = document.querySelector(
      '.dialog-custom-select[data-name="consorcio"]',
    );
    const dialogEntrada = document.getElementById(
      "dialog-entrada",
    ) as HTMLInputElement;

    if (setSelect && dialogLocSelect) setSelect(dialogLocSelect, localizacao);
    if (setSelect && dialogConsSelect) setSelect(dialogConsSelect, consorcio);
    if (dialogEntrada) dialogEntrada.value = entrada;

    const dialog = document.getElementById(
      "budget-dialog",
    ) as HTMLDialogElement;
    dialog?.showModal();
  });
</script>

<style>
  .hero-section {
    position: relative;
    width: 100%;
    background-color: white;
    overflow-x: clip;
    padding: 0px 0 80px;
    margin-top: -70px;
  }

  .hero-container {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 40px;
    min-height: 580px;
    height: auto;
  }

  .hero-content {
    flex: 1;
    min-width: 0;
  }

  .partners-badge {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
    background: #f8f9fa;
    padding: 10px 20px;
    border-radius: 100px;
    margin-top: 60px;
    margin-bottom: 24px;
    border: 1px solid #eee;
  }

  .partners-text {
    font-size: 11px;
    font-weight: 700;
    color: var(--gray-light);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .partners-logos {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .partners-logos img {
    height: 24px;
    width: auto;
    filter: grayscale(100%) opacity(0.6);
    transition: all 0.3s ease;
  }

  .partners-logos img:hover {
    filter: grayscale(0%) opacity(1);
    transform: scale(1.05);
  }

  .hero-content h1 {
    font-size: 72px;
    line-height: 1.15;
    margin-bottom: 20px;
    color: var(--gray-dark);
    font-weight: 900;
  }

  .hero-content h1 em {
    font-style: normal;
    color: var(--primary);
    font-weight: 900;
  }

  .hero-description {
    font-size: 14px;
    line-height: 1.7;
    font-weight: 600;
    color: var(--gray-light);
    margin-bottom: 40px;
    max-width: 480px;
  }

  /* ===== Info Bar / Form ===== */
  .hero-info-bar {
    display: flex;
    align-items: center;
    background: white;
    border: 1px solid #e8e8e8;
    border-radius: 16px;
    padding: 0 12px;
    gap: 0;
    max-width: 750px;
  }

  .info-item {
    display: flex;
    flex-direction: column;
    padding: 14px 12px;
    gap: 6px;
    flex: 1;
    min-width: 0;
    position: relative;
  }

  .info-label {
    font-size: 10px;
    color: var(--gray-light);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: default;
  }

  /* ===== Custom Select ===== */
  .custom-select {
    position: relative;
  }

  .select-trigger {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    font-family: "Montserrat", sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--gray-dark);
    cursor: pointer;
    width: 100%;
    text-align: left;
    outline: none;
  }

  .select-value {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .select-arrow {
    color: #aaa;
    flex-shrink: 0;
    transition: transform 0.25s ease;
    margin-left: auto;
  }

  .custom-select.open .select-arrow {
    transform: rotate(180deg);
  }

  .select-dropdown {
    position: absolute;
    top: calc(100% + 12px);
    left: -12px;
    min-width: calc(100% + 36px);
    background: white;
    border: 1px solid #eee;
    border-radius: 12px;
    padding: 8px 6px;
    margin: 0;
    list-style: none;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.12);
    z-index: 100;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .custom-select.open .select-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .select-dropdown li {
    padding: 10px 14px;
    font-size: 13px;
    font-weight: 500;
    color: var(--gray-dark);
    cursor: pointer;
    white-space: nowrap;
    border-radius: 8px;
    margin-bottom: 2px;
    transition: all 0.2s ease;
  }

  .select-dropdown li:last-child {
    margin-bottom: 0;
  }

  .select-dropdown li:hover {
    background: #f0f4ff;
    color: var(--primary);
  }

  .select-dropdown li.selected {
    color: var(--primary);
    font-weight: 600;
    background: rgba(34, 97, 255, 0.06);
  }

  /* ===== Text Input ===== */
  .info-input {
    font-size: 14px;
    color: var(--gray-dark);
    font-weight: 600;
    border: none;
    background: transparent;
    padding: 0;
    margin: 0;
    font-family: "Montserrat", sans-serif;
    outline: none;
    width: 100%;
    caret-color: #000;
  }

  .info-input::placeholder {
    color: #ccc;
    font-weight: 500;
  }

  .info-input:focus {
    color: var(--primary);
  }

  /* ===== Divider ===== */
  .info-divider {
    width: 1px;
    height: 40px;
    background: #e8e8e8;
    flex-shrink: 0;
  }

  /* ===== CTA Button ===== */
  .btn-simulacao {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--primary);
    color: white;
    padding: 14px 24px;
    border-radius: 16px;
    font-weight: 600;
    font-size: 13px;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.3s ease;
    margin-left: auto;
    margin-right: 4px;
    border: none;
    cursor: pointer;
    font-family: "Montserrat", sans-serif;
  }

  .btn-simulacao:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(34, 97, 255, 0.3);
  }

  /* ===== Hero Image ===== */
  .hero-image-wrapper {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .hero-img {
    width: 200%;
    max-width: 1560px;
    height: auto;
    object-fit: contain;
    border-radius: 16px;
    margin-right: -600px;
    margin-top: 50px;
  }

  /* ===== Mobile ===== */
  @media (max-width: 992px) {
    .partners-badge {
      margin-top: 0;
      justify-content: center;
      padding: 12px 16px;
      margin-bottom: 24px;
    }

    .partners-logos img {
      height: 16px;
    }

    .hero-section {
      padding: 30px 0 0;
      min-height: auto;
      overflow: hidden;
      margin-top: 0px;
    }

    .hero-container {
      flex-direction: column;
      gap: 24px;
      height: auto;
    }

    .hero-content h1 {
      font-size: 36px;
    }

    .hero-description {
      font-size: 13px;
      margin-bottom: 24px;
    }

    .hero-info-bar {
      flex-direction: column;
      align-items: stretch;
      max-width: 100%;
      padding: 0;
    }

    .info-item {
      padding: 14px 20px;
    }

    .info-divider {
      width: 100%;
      height: 1px;
    }

    .select-dropdown {
      left: 0;
      min-width: 100%;
    }

    .btn-simulacao {
      margin: 0;
      border-radius: 0 0 16px 16px;
      padding: 16px 24px;
    }

    .hero-image-wrapper {
      display: none;
    }

    .hero-img {
      width: 100%;
      max-width: 100%;
      margin: 0;
      margin-right: 0;
      margin-top: 0;
      border-radius: 0;
    }
  }
</style>
