---
// src/components/Dialog/Dialog.astro
---

<dialog id="budget-dialog" class="budget-dialog">
  <div class="dialog-header">
    <h3>Solicitar Orçamento</h3>
    <button class="close-btn" id="close-budget-dialog" aria-label="Fechar">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
  
  <form class="budget-form">
    <div class="form-group">
      <label for="name">Nome completo</label>
      <input type="text" id="name" name="name" placeholder="Digite seu nome" required />
    </div>
    <div class="form-group">
      <label for="email">E-mail</label>
      <input type="email" id="email" name="email" placeholder="Seu melhor e-mail" required />
    </div>
    <div class="form-group">
      <label for="phone">Telefone / WhatsApp</label>
      <input type="tel" id="phone" name="phone" placeholder="(00) 00000-0000" required />
    </div>
    <div class="form-group">
      <label for="value">Valor do Consórcio</label>
      <select id="value" name="value" required>
        <option value="" disabled selected>Selecione um valor desejado</option>
        <option value="50k-100k">R$ 50.000 a R$ 100.000</option>
        <option value="100k-250k">R$ 100.000 a R$ 250.000</option>
        <option value="250k-500k">R$ 250.000 a R$ 500.000</option>
        <option value="500k+">Acima de R$ 500.000</option>
      </select>
    </div>
    <button type="submit" class="btn-primary submit-btn">Enviar Solicitação</button>
  </form>
</dialog>

<script>
  // Script associado ao dialog e botão do header. Em Astro, os scripts são empacotados pelo vite.
  const dialog = document.getElementById('budget-dialog') as HTMLDialogElement;
  const openBtns = document.querySelectorAll('#open-budget-dialog, #open-budget-dialog-mobile, #open-budget-dialog-hero');
  const closeBtn = document.getElementById('close-budget-dialog');

  openBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      dialog?.showModal();
    });
  });

  closeBtn?.addEventListener('click', () => {
    dialog?.close();
  });

  // Fechar ao clicar fora
  dialog?.addEventListener('click', (e) => {
    const dialogDimensions = dialog.getBoundingClientRect()
    if (
      e.clientX < dialogDimensions.left ||
      e.clientX > dialogDimensions.right ||
      e.clientY < dialogDimensions.top ||
      e.clientY > dialogDimensions.bottom
    ) {
      dialog.close()
    }
  });
</script>

<style>
  .budget-dialog {
    padding: 0;
    margin: auto;
    border: none;
    border-radius: 12px;
    background: white;
    width: 90%;
    max-width: 500px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.2);
    /* Início invisível para animação */
    opacity: 0;
  }

  .budget-dialog::backdrop {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(3px);
  }

  .budget-dialog[open] {
    animation: slideIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes slideIn {
    from {
      opacity: 0;
      transform: translateY(-40px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .dialog-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
    border-bottom: 1px solid #eeeeee;
  }

  .dialog-header h3 {
    margin: 0;
    color: var(--primary);
    font-size: 20px;
    font-weight: 700;
  }

  .close-btn {
    background: none;
    color: var(--text-light);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    transition: background 0.2s, color 0.2s;
  }

  .close-btn:hover {
    background: #f0f0f0;
    color: var(--text-main);
  }

  .budget-form {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group label {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-main);
  }

  .form-group input, .form-group select {
    padding: 12px 14px;
    border: 1px solid #dddddd;
    border-radius: 6px;
    font-size: 15px;
    font-family: 'Poppins', sans-serif;
    color: var(--text-main);
    transition: border-color 0.3s;
  }

  .form-group input:focus, .form-group select:focus {
    border-color: var(--primary);
    outline: none;
  }

  .submit-btn {
    margin-top: 8px;
    width: 100%;
    font-size: 16px;
    padding: 14px;
  }


</style>
