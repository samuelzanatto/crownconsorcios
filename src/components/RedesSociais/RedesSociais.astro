---
// src/components/RedesSociais/RedesSociais.astro
---

<section id="redes" class="redes-section">
  <div class="redes-container container">
    <div class="redes-content">
      <h2 class="title">Siga-nos nas Redes Sociais</h2>
      <p class="subtitle">
        Fique por dentro de promoções, oportunidades de grupos em andamento e
        conteúdos exclusivos que preparamos para você.
      </p>

      <div class="social-links">
        <a
          href="https://instagram.com/crownconsorcios"
          target="_blank"
          class="social-icon"
          aria-label="Instagram"
        >
          <svg
            width="28"
            height="28"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <circle cx="12" cy="12" r="3"></circle>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"
            ></circle>
          </svg>
        </a>
        <a
          href="https://facebook.com/crownconsorcios"
          target="_blank"
          class="social-icon"
          aria-label="Facebook"
        >
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
            ></path>
          </svg>
        </a>
        <a
          href="https://wa.me/5567000000"
          target="_blank"
          class="social-icon"
          aria-label="WhatsApp"
        >
          <svg width="28" height="28" viewBox="0 0 32 32" fill="currentColor">
            <path
              d="M16.003 0C7.165 0 0 7.164 0 16c0 2.823.737 5.47 2.024 7.77L0 32l8.468-2.004A15.938 15.938 0 0 0 16.003 32C24.837 32 32 24.836 32 16S24.837 0 16.003 0zm0 29.292a13.243 13.243 0 0 1-6.738-1.843l-.483-.287-5.024 1.188 1.21-4.893-.315-.502A13.207 13.207 0 0 1 2.708 16c0-7.334 5.965-13.296 13.295-13.296 7.33 0 13.29 5.962 13.29 13.296 0 7.33-5.96 13.292-13.29 13.292zm7.291-9.961c-.4-.2-2.361-1.165-2.728-1.298-.366-.133-.632-.2-.898.2-.266.4-1.032 1.298-1.265 1.565-.234.266-.467.299-.867.1-2.293-1.147-3.798-2.048-5.3-4.64-.4-.686.4-.637.847-2.12.1-.2.05-.367-.033-.567-.083-.2-.9-2.161-1.232-2.96-.325-.78-.656-.673-.9-.687-.232-.013-.5-.016-.766-.016-.266 0-.699.1-1.065.5-.366.4-1.399 1.365-1.399 3.327 0 1.962 1.432 3.861 1.631 4.127.2.266 2.793 4.261 6.77 5.98 2.517 1.086 3.505 1.18 4.764.993.766-.114 2.361-.965 2.694-1.897.333-.932.333-1.731.233-1.897-.1-.166-.366-.266-.766-.466z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .redes-section {
    padding: 50px 50px;
    margin: 0px 450px 150px 450px;
    background: var(--primary);
    border-radius: 64px;
  }

  .redes-content {
    color: white;
  }

  .title {
    font-size: 32px;
    font-weight: 800;
    color: white;
    margin-bottom: 12px;
  }

  .subtitle {
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 24px;
    max-width: 500px;
  }

  .social-links {
    display: flex;
    gap: 16px;
  }

  .social-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .social-icon:hover {
    background: white;
    color: var(--primary);
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.15);
  }

  @media (max-width: 992px) {
    .redes-section {
      padding: 40px 0;
    }

    .title {
      font-size: 24px;
    }
  }
</style>
