---
// src/components/QuemSomos/QuemSomos.astro
---

<section id="quem-somos" class="quem-somos-section">
  <div class="qs-container container">
    <div class="qs-text-col">
      <div class="qs-header">
        <h2 class="qs-pretitle">Por Dentro da</h2>
        <div class="qs-crown-container">
          <h3 class="qs-crown">CROWN</h3><div class="qs-line"></div>
        </div>
      </div>

      <p class="qs-text">
        Fundada por Paulo Afonso Júnior, CFP® — planejador financeiro com mais
        de uma década de experiência em grandes instituições financeiras,
        certificações de alto nível como CEA e CFP®, e vivência estratégica na
        gestão de patrimônio e alta renda.
      </p>
    </div>

    <div class="qs-image-col">
      <img
        src="/images/paulo1.jpeg"
        alt="Consultor Crown Consórcios"
        class="qs-img"
      />
    </div>
  </div>
</section>

<style>
  .quem-somos-section {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 80px 0;
    background: var(--primary);
    overflow: hidden;
    min-height: 700px;
  }

  .qs-container {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 60px;
  }

  .qs-text-col {
    flex: 1;
    color: white;
  }

  .qs-header {
    margin-bottom: 30px;
  }

  .qs-pretitle {
    font-size: 64px;
    color: white;
    margin: 0;
    font-weight: 900;
    line-height: 1.2;
  }

  .qs-crown-container {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .qs-crown {
    font-size: 56px;
    font-weight: 900;
    color: white;
    letter-spacing: 2px;
    margin: 4px 0 16px 0;
    line-height: 1;
  }

  .qs-line {
    width: 200px;
    height: 6px;
    background: white;
  }

  .qs-text {
    font-size: 20px;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.92);
    margin-bottom: 16px;
    max-width: 520px;
  }

  .qs-image-col {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .qs-img {
    width: 100%;
    max-width: 620px;
    height: auto;
    object-fit: cover;
    border-radius: 16px;
  }

  @media (max-width: 992px) {
    .quem-somos-section {
      padding: 60px 0;
      height: auto;
    }

    .qs-container {
      flex-direction: column;
      gap: 32px;
    }

    .qs-pretitle {
      font-size: 36px;
    }

    .qs-crown {
      font-size: 32px;
    }

    .qs-line {
      width: 100px;
      height: 4px;
    }

    .qs-text {
      font-size: 14px;
      max-width: 100%;
    }

    .qs-img {
      max-width: 100%;
      border-radius: 12px;
    }
  }

  @media (max-width: 480px) {
    .quem-somos-section {
      padding: 48px 0;
    }

    .qs-pretitle {
      font-size: 28px;
    }

    .qs-crown {
      font-size: 26px;
    }

    .qs-header {
      margin-bottom: 20px;
    }
  }
</style>
